# Tuk Talk Thai — local environment variables.
# Copy this file to .env.local and fill in your Supabase + OneSignal project values.
# .env.local is gitignored. Production values are set in Vercel project settings.

# Supabase — find these at: supabase.com → your project → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_KEY=sb_publishable_replace_with_your_key

# OneSignal — find this at: onesignal.com → your app → Settings → Keys & IDs.
# The App ID is safe to expose (security comes from your domain restrictions).
# The REST API Key is NEVER set here — it lives only in Supabase Edge Function secrets.
VITE_ONESIGNAL_APP_ID=00000000-0000-0000-0000-000000000000

# Support section (all optional). The public "Support Tuk Talk Thai" section
# always shows both cards; leaving a value empty just shows a "Coming soon"
# state for that card instead of a link or a fake destination.
#   VITE_BUY_ME_A_COFFEE_URL  — a real, confirmed Buy Me a Coffee URL.
#   VITE_CRYPTO_WALLET_ADDRESS — a real wallet address (never invent one).
#   VITE_CRYPTO_NETWORK       — the network/token label, e.g. "USDT (TRC-20)".
#   VITE_CRYPTO_QR_IMAGE      — public path to an approved QR image that encodes
#                               exactly the address above, e.g. /donate/crypto-qr.png
VITE_BUY_ME_A_COFFEE_URL=
VITE_CRYPTO_WALLET_ADDRESS=
VITE_CRYPTO_NETWORK=
VITE_CRYPTO_QR_IMAGE=
