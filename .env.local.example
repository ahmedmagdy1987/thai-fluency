# Tuk Talk Thai — local environment variables.
# Copy this file to .env.local and fill in your Supabase project values.
# .env.local is gitignored. Production values are set in Vercel project settings.

# Find these at: supabase.com → your project → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_KEY=sb_publishable_replace_with_your_key
